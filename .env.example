# Copy this file to .env and fill in real values as needed. .env is
# gitignored - never commit real values. Every variable below is what the
# code actually reads today (see docs/API_KEYS_AND_MANUAL_REFRESH.md for the
# audit this was generated from) - nothing here is speculative.
#
# NONE of these are required for refresh:incremental / process:records to
# run. OpenAlex (the only live data source the refresh pipeline calls) is a
# free, open API - it needs no key at all. Every variable below has a safe
# default and the pipeline degrades gracefully (or simply uses the default)
# when it is unset.

# --- OpenAlex fetch identification (scripts/ingestion/config.mjs) ---
# Identifies requests in OpenAlex's User-Agent so they land in the "polite
# pool" (fewer rate limits). Falls back to a placeholder that still works.
OPENALEX_EMAIL=replace_me@example.com

# --- OpenAlex fetch tuning (optional, both default to 2) ---
# scripts/ingestion/fetchOpenAlex.mjs (full topic sweep)
OPENALEX_PAGES_PER_QUERY=2
# scripts/ingestion/fetchGlobalUpdates.mjs (incremental refresh window)
OPENALEX_INCREMENTAL_PAGES_PER_QUERY=2

# --- AI image-curation API (optional, future integration) ---
# scripts/ingestion/aiCuration/config.mjs + curateImages.mjs. Leave all
# three blank to keep curate:images running in "not configured" (no-op)
# mode - every image candidate stays "pending", nothing is hidden or
# changed. This is NOT called by refresh:incremental today.
AI_CURATION_API_URL=
AI_CURATION_API_KEY=
AI_CURATION_MODEL=
AI_CURATION_MIN_SCORE=60

# --- Backend API server (server/server.mjs) ---
API_PORT=8787
API_HOST=127.0.0.1
# Unset (default) = POST /api/admin/refresh-data stays disabled (404).
# Set to a long random value to enable it, and send it as
# "Authorization: Bearer <value>".
ADMIN_TOKEN=
