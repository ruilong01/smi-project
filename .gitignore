node_modules/
dist/
work/
# Secrets - never committed. .env.example is the only exception (placeholder
# values only, see docs/API_KEYS_AND_MANUAL_REFRESH.md).
.env
.env.local
*.env
.env.*
!.env.example
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Server-side data-refresh output: lives in the persistent bind-mounted
# data/ dir on the deployed box (see compose.yaml, docs/AWS_DATA_REFRESH.md),
# not in git history. data/processed/*.json stays committed (small,
# meaningful summaries, same convention as src/data/generated/).
data/raw/openalex/
data/raw/media-candidates/
data/logs/
data/processed/.tmp-*/
data/processed/*.tmp-*.json
data/processed/*.bak

# verify:incremental-comparison's fixture-test output - regenerated on
# every run from data/test/incoming-records-sample.json, never the real
# comparison state, must never be confused with data/processed/*.json.
data/processed/test/

# discover:institution-images:sample's generated sample output - same
# convention as data/processed/test/ above (regenerated test/demo output,
# never a real asset).
public/assets/test/

# Open-access PDF ingestion server-style storage (see
# docs/OPEN_ACCESS_PDF_INGESTION.md): downloaded PDFs, raw API response
# caches, staging candidate lists, runtime manifests/status, and logs all
# live on the deployed box's disk, never in git history. Directories are
# created at runtime by discoverOpenAccessPdfs.mjs (fs.mkdir recursive),
# same convention as data/processed/test/ - nothing to commit here ever.
data/server/
